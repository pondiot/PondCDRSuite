# Connection settings
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USER=username
SFTP_PASSWORD=password

# Directories
LOCAL_DIR=/path/to/local/cdr/directory
REMOTE_DIR=/path/to/remote/cdr/directory

# Sync settings
PARALLEL_TRANSFERS=2
DELETE_MISSING=false

# Timeout in seconds (default: 300, use 0 for no timeout)
# Set to 0 for initial sync with large amount of files
TIMEOUT=300

# Notification settings (per-client)
SEND_TELEGRAM=false
SEND_EMAIL=false
